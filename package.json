{
  "name": "community-risk-warning-system",
  "private": true,
  "version": "0.2.0",
  "description": "Electron desktop app for community risk warning and VLM-assisted monitoring.",
  "author": "community-risk-warning-system contributors",
  "main": "./dist/main/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "download-model": "node scripts/download-model.js",
    "package": "electron-builder --win",
    "dev:web": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "concurrently \"npm run dev:web\" \"npm run dev:server\"",
    "typecheck": "tsc -p tsconfig.app.json --noEmit --pretty false --tsBuildInfoFile node_modules/.cache/tsconfig.app.typecheck.tsbuildinfo && tsc -p tsconfig.node.json --noEmit --pretty false --tsBuildInfoFile node_modules/.cache/tsconfig.node.typecheck.tsbuildinfo && tsc -p electron/tsconfig.json --noEmit --pretty false --tsBuildInfoFile node_modules/.cache/electron.typecheck.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepackage": "npm run download-model"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow/tfjs": "^4.22.0",
    "antd": "^6.4.2",
    "axios": "^1.16.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mpegts.js": "^1.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "^41.6.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "cacache": {
      "glob": "^13.0.0"
    },
    "@electron/asar": "^4.2.0",
    "electron": {
      "@electron/get": "^4.0.3"
    },
    "global-agent": "^4.1.3",
    "temp": {
      "rimraf": "^6.0.0"
    }
  },
  "build": {
    "appId": "com.community-risk-warning.app",
    "productName": "险封·社区风险预警平台",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      ".env.server.example"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "asar": true,
    "extraResources": [
      {
        "from": "resources/vlm",
        "to": "vlm",
        "filter": [
          "**/*",
          "!Qwen3.5-4B.Q4_K_M.gguf",
          "!mmproj-BF16.gguf"
        ]
      }
    ]
  }
}
