VITE_APP_TITLE=险封·社区风险预警平台

# 前端 API 代理地址。开发时可为空，配合 Vite /api -> 本地后端代理。
VITE_API_BASE_URL=

# 百度地图 JSAPI GL
VITE_BAIDU_MAP_AK=请填写你的百度地图浏览器端AK
VITE_BAIDU_MAP_STYLE_ID=
VITE_BAIDU_MAP_CENTER_LNG=118.796877
VITE_BAIDU_MAP_CENTER_LAT=32.060255
VITE_BAIDU_MAP_ZOOM=16

# 前端调用路径。VITE_* 会进入浏览器代码，不要在 VITE_* 中放真实密钥。
VITE_QWEN_PROXY_PATH=/api/qwen/chat/completions
VITE_QWEN_MODEL=qwen3-vl-plus

# 演示视频流（可选）
VITE_DEMO_STREAM_URL=
VITE_DEMO_STREAM_TYPE=flv

# 目标检测预筛（可选）
VITE_DETECTION_LABELS=person,car,truck,bus,bicycle,motorcycle,dog,backpack,handbag,suitcase,chair,couch,bench,potted plant
VITE_DETECTION_MIN_SCORE=0.35
# 可选：自托管 COCO-SSD model.json 地址。留空时使用上游默认 Google Storage 模型。
VITE_DETECTION_MODEL_URL=

# 本地后端代理监听端口
SERVER_HOST=127.0.0.1
SERVER_PORT=8787

# 允许前端开发域名
CORS_ORIGIN=http://localhost:5173
ALLOW_LOCAL_FILE_ORIGINS=false
REQUEST_BODY_LIMIT=2mb
CHAT_REQUESTS_PER_MINUTE=30
AUTH_ATTEMPTS_PER_MINUTE=20
STATUS_REQUESTS_PER_MINUTE=60
MAX_CHAT_MESSAGES=16
MAX_CHAT_TOKENS=2048
MAX_UPSTREAM_RESPONSE_BYTES=2097152
LOG_MODEL_OUTPUT=false

# 本地 VLM 失败时是否允许把图像请求转发到已配置的云端模型。涉及监控画面外发，默认关闭。
ALLOW_CLOUD_FALLBACK=false

# 可选：为 /api/qwen/chat/completions 与 /api/ollama/chat/completions 启用服务端 token 校验。
# 当 SERVER_HOST 绑定非本机地址时必须设置至少 32 字节的高熵随机值，否则代理拒绝启动。
LOCAL_PROXY_TOKEN=

# Qwen OpenAI-Compatible 接口配置。出于 SSRF 防护，代理只接受源码中固定列出的上游地址。
# ESA Pages 可只配置 QWEN_API_KEY；如使用 BigModel 兼容接口，再设置 QWEN_BASE_URL。
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen3-vl-plus
QWEN_TIMEOUT=60000

# 本地 VLM 运行配置
VLM_HOST=127.0.0.1
VLM_PORT=11434
# 独立代理连接受保护 llama-server 时填写；Electron 模式会自动生成并覆盖会话密钥。
VLM_API_KEY=
VLM_MODEL=qwen3.5-4b-mtp:q4_k_m
VLM_FORCE_CPU=false
VLM_GPU_LAYERS=99
VLM_CONTEXT_SIZE=4096
VLM_BATCH_SIZE=512
VLM_UBATCH_SIZE=256
VLM_STARTUP_TIMEOUT_MS=60000

# KV cache 量化类型，可降低显存占用（需 flash-attn，已默认开启）。
# 可选：f16（默认，精度最高）、q8_0（近乎无损、约省一半 KV 显存，8GB 显存推荐）、q4_0（最省但有精度损失）。
VLM_CACHE_TYPE_K=f16
VLM_CACHE_TYPE_V=f16

# MTP（Multi-Token Prediction 推测解码）默认关闭，原因：
#   1) --spec-type 等参数只存在于 llama.cpp 的 MTP 专用分支，官方预编译包（本项目所用）不识别，会导致启动失败；
#   2) MTP 与 mmproj 视觉编码器互斥，本项目以视觉研判为核心，开启会丧失视觉能力；
#   3) MTP 只加速文本生成、对视觉编码无效，社区共识为显存 <24GB 不建议启用。
# 仅当改用支持 MTP 的 llama.cpp 构建 + 无 mmproj 的纯文本 MTP 模型时，才设为 true。
VLM_MTP_ENABLED=false
VLM_MTP_DRAFT_TOKENS=4
